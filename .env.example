# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automated_ads

# Database Connection Pool Configuration
DB_POOL_MAX=20              # Maximum connections (Railway recommends 15 in production)
DB_POOL_MIN=2               # Minimum idle connections
DB_IDLE_TIMEOUT=30000       # Idle connection timeout in ms
DB_CONNECTION_TIMEOUT=5000  # Connection acquisition timeout in ms
DB_STATEMENT_TIMEOUT=30000  # Query timeout in ms (PostgreSQL server-side)

# Session
SESSION_SECRET=change-this-in-production-use-long-random-string

# CSRF Protection
# REQUIRED for production: Generate with: openssl rand -hex 32
CSRF_SECRET=your-csrf-secret-here-generate-with-openssl-rand-hex-32

# Server
PORT=3000
NODE_ENV=development

# Monitoring & Performance Tracking
ENABLE_MONITORING=true      # Enable performance metrics and error tracking

# Sentry Error Monitoring (Optional)
# Get your DSN from: https://sentry.io
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENABLED=false        # Set to true in production to enable Sentry

# Gemini API (Required for AI features)
# At least ONE of the following three keys is required — the server checks them in order.
# Get your API key from: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-gemini-api-key-here
GEMINI_API_KEY=                # Alternative to GOOGLE_API_KEY (either one works)
GOOGLE_GENAI_API_KEY=          # Third alternative used by agentRunner

# Redis Configuration (for rate limiting and BullMQ job queue)
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# Alternative Redis config (used if REDIS_URL is not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# OpenTelemetry Configuration
# ========================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=automated-ads-agent
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your-axiom-api-token,X-Axiom-Dataset=automated-ads-agent

# ========================================
# Cloudinary (Image Storage)
# ========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========================================
# Firecrawl (Website Scraping)
# Get your API key from: https://firecrawl.dev
# ========================================
FIRECRAWL_API_KEY=your-firecrawl-api-key

# ========================================
# n8n Multi-Platform Posting (Phase 8.1)
# ========================================
N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud
N8N_API_KEY=n8n_api_xyz123  # Optional but recommended for webhook auth

# n8n Webhook Security
# REQUIRED: HMAC-SHA256 signature validation for webhook callbacks
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=your-webhook-secret-here-generate-with-openssl-rand-hex-32

# Already exists for encryption
API_KEY_ENCRYPTION_KEY=your-base64-encryption-key

# ========================================
# OAuth 2.0 (Social Media Connect)
# ========================================

# LinkedIn OAuth 2.0
# Create an app at https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X OAuth 2.0 (PKCE)
# Create an app at https://developer.x.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Base URL for OAuth callbacks (must match registered redirect URIs)
# In production: https://your-domain.com
OAUTH_CALLBACK_BASE_URL=http://localhost:5000

# ========================================
# File Search Configuration (RAG System)
# ========================================
FILESEARCH_CHUNK_SIZE=500
FILESEARCH_CHUNK_OVERLAP=50
FILESEARCH_STORE_NAME=nds-copywriting-rag

# ========================================
# Feature Flags (Phase 2 Duplication Removal)
# ========================================
# USE_LEGACY_PROMPT_ENDPOINT: Keep deprecated /api/prompt-suggestions endpoint active
# Set to 'false' after monitoring period to remove legacy endpoint
USE_LEGACY_PROMPT_ENDPOINT=false

# ========================================
# Railway Deployment (API Access)
# ========================================
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_ENVIRONMENT_ID=

# ========================================
# Application URL & CORS
# ========================================
# Comma-separated allowed origins for CORS (defaults to http://localhost:PORT)
ALLOWED_ORIGINS=
# Public URL of the app (used for WebSocket origin checks in production)
APP_URL=

# ========================================
# Gemini Model Overrides (Optional)
# ========================================
# Override default model names for specific services
GEMINI_MODEL=                       # Main image generation model (default: gemini-3-pro-image-preview)
GEMINI_REASONING_MODEL=             # Reasoning model for agent/idea bank (default: gemini-3-flash-preview)
GEMINI_TEXT_MODEL=                   # Text model for enrichment (default: gemini-3-flash)
GEMINI_VISION_MODEL=                # Vision model for image analysis (default: gemini-3-pro-preview)
GEMINI_SEARCH_MODEL=                # Search model for source discovery (default: gemini-3-flash)
GEMINI_EXTRACTION_MODEL=            # Pattern extraction model (default: gemini-3-pro-preview)
GEMINI_ENRICHMENT_MODEL=            # Product enrichment model (default: gemini-3-pro-preview)
GEMINI_PRIVACY_MODEL=               # Privacy filter model (default: gemini-3-flash)
VEO_MODEL=                          # Video generation model (default: veo-2.0-generate-001)

# ========================================
# Gemini Resilience / Circuit Breaker
# ========================================
GEMINI_CIRCUIT_FAILURE_THRESHOLD=   # Failures before circuit opens (default: 5)
GEMINI_CIRCUIT_COOLDOWN_MS=         # Cooldown before retry in ms (default: 30000)
GEMINI_REQUEST_TIMEOUT_MS=          # Per-request timeout in ms (default: 30000)

# ========================================
# Google Cloud Monitoring (Optional)
# ========================================
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=     # Path to service account JSON file
GOOGLE_CLOUD_CREDENTIALS_JSON=      # Inline JSON credentials (alternative to file)

# ========================================
# Push Notifications (VAPID / Web Push)
# ========================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=                        # mailto: address for VAPID (e.g., mailto:admin@example.com)

# ========================================
# Notification Channels (Optional)
# ========================================
SLACK_ALERTS_WEBHOOK_URL=           # Slack webhook for alert notifications
DISCORD_ALERTS_WEBHOOK_URL=         # Discord webhook for alert notifications
SLACK_WEBHOOK_URL=                  # Slack webhook for observability events

# ========================================
# GitHub Integration (Observability Webhook)
# ========================================
GITHUB_TOKEN=                       # GitHub PAT for creating issues from alerts
GITHUB_REPO=                        # GitHub repo in "owner/repo" format

# ========================================
# Analytics (PostHog)
# ========================================
POSTHOG_API_KEY=
POSTHOG_HOST=                       # PostHog host (default: https://us.i.posthog.com)

# ========================================
# Worker Configuration
# ========================================
WORKER_CONCURRENCY=                 # BullMQ worker concurrency (default: 5)

# ========================================
# Logging
# ========================================
LOG_LEVEL=                          # Pino log level: debug, info, warn, error (default: debug in dev, info in prod)

# ========================================
# Feature Flags & Debug
# ========================================
SKIP_SCHEMA_PUSH=false              # Skip Drizzle schema push on startup
ENABLE_DEMO_MODE=false              # Enable demo login in production (NOT recommended)
ENABLE_DEBUG_CONTEXT=false          # Include debug context in idea bank responses
SAFETY_FAIL_OPEN=false              # Content safety fails open in non-production (NOT for production)

# ========================================
# Pricing Estimator
# ========================================
PRICING_TOKEN_USD_PER_1K=           # Override token cost per 1K tokens (default: 0)
